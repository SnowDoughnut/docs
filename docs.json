{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Knowledge base",
  "description": "Onboarding, employee handbook, HR guides, IT help, company policies, and department runbooks.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "Welcome",
        "tabs": [
          {
            "tab": "Get started",
            "pages": [
              "overview",
              "quick-starts",
              "glossary",
              "how-to-use-this-knowledge-base"
            ]
          },
          {
            "tab": "Find what you need",
            "dropdowns": [
              {
                "dropdown": "By Platform",
                "pages": [
                  "google",
                  "linkedin",
                  "meta",
                  "untitled-page",
                  "email"
                ]
              },
              {
                "dropdown": "By Document Type",
                "pages": [
                  "untitled-page",
                  "sops",
                  "how-tos",
                  "untitled-page",
                  "brand-documents",
                  "reports",
                  "tools"
                ]
              },
              {
                "dropdown": "By Marketing Type",
                "pages": [
                  "oragni",
                  "untitled-page",
                  "paid-search",
                  "paid-social",
                  "content-marketing",
                  "analytics"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Submit IT ticket",
        "href": "/it-security/access-requests"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Employee portal",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
